{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Backend",
      "type": "shell",
      "command": "dotnet run --launch-profile https",
      "options": {
        "cwd": "${workspaceFolder}/server/BranchOps.Api"
      },
      "isBackground": true,
      "problemMatcher": "$msCompile",
      "presentation": {
        "group": "devServers",
        "reveal": "always"
      }
    },
    {
      "label": "Run Frontend",
      "type": "shell",
      "command": "bun run dev",
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "devServers",
        "reveal": "always"
      }
    },
    {
      "label": "Run All",
      "dependsOn": ["Run Backend", "Run Frontend"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
